{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"title": "playful-cn registry",
	"type": "object",
	"required": ["name", "source", "styles", "items"],
	"properties": {
		"name": { "type": "string" },
		"source": {
			"type": "object",
			"required": ["type", "owner", "repo", "branch"],
			"properties": {
				"type": { "const": "github-raw" },
				"owner": { "type": "string" },
				"repo": { "type": "string" },
				"branch": { "type": "string" }
			}
		},
		"styles": {
			"type": "object",
			"required": ["name", "files"],
			"properties": {
				"name": { "type": "string" },
				"files": { "type": "array", "items": { "type": "string" } }
			}
		},
		"items": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["name", "type", "files", "dependencies", "registryDependencies"],
				"properties": {
					"name": { "type": "string" },
					"type": { "enum": ["component", "lib"] },
					"title": { "type": "string" },
					"files": { "type": "array", "items": { "type": "string" } },
					"dependencies": { "type": "array", "items": { "type": "string" } },
					"registryDependencies": { "type": "array", "items": { "type": "string" } }
				}
			}
		}
	}
}
